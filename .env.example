# Plausible Analytics
NEXT_PUBLIC_PLAUSIBLE_DOMAIN="kompwatch.com"
PLAUSIBLE_HOST="https://analytics.webgeeksai.in"
# API key for reading stats (aggregate metrics, top pages, top sources).
# Generate at analytics.webgeeksai.in/settings/api-keys with scope stats:read:*.
