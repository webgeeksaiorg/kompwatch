# Optional: only needed to run `npm run plausible:add-site`. Generate at
# analytics.webgeeksai.in/settings/api-keys with scope sites:provisioning:*.
PLAUSIBLE_PROVISIONING_TOKEN=""

# Internal: used by orchestrator agents
